{
  "ConnectionStrings": {
    "DefaultConnection": "${DB_DEFAULT}",
    "ReportingDb": "${DB_REPORTING}",
    "AseDb": "${DB_ASE}"
  },

  "Jwt": {
    "Issuer": "CleanArchJwt",
    "Audience": "CleanArchJwtAudience",
    "Secret": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_VALUE_32BYTES_MINIMUM",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
