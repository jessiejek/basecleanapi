# =========================
# Database Connections
# =========================
DB_DEFAULT=Server=YOUR_SQL_SERVER;Database=CleanArchDb;User Id=your_user;Password=your_password;TrustServerCertificate=True;
DB_REPORTING=Server=YOUR_SQL_SERVER;Database=ReportingDb;User Id=your_user;Password=your_password;TrustServerCertificate=True;
DB_ASE=Data Source=YOUR_ASE_HOST;Port=5000;Database=LegacyDb;Uid=your_user;Pwd=your_password;

# =========================
# JWT Configuration
# =========================
JWT__ISSUER=CleanArchJwt
JWT__AUDIENCE=CleanArchJwtAudience
JWT__SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_VALUE_32BYTES_MINIMUM
JWT__ACCESSTOKENMINUTES=15
JWT__REFRESHTOKENDAYS=7
